# Copy this file to .env and edit values:
#   cp .env.example .env
#
# .env is gitignored and will NOT be committed.
# - go run / binary: auto-loads .env (does not override real env vars)
# - docker compose: reads .env via env_file + variable substitution

ADDR=:8080

# Leave empty to disable auth (local use).
# When set, API + Web UI share this key (send header X-API-Key).
API_KEY=

# Host binary default. Docker Compose forces DB_PATH=/data/paopao.db
DB_PATH=./data/paopao.db

UPSTREAM_BASE=https://query.paopaodw.com
UPSTREAM_TIMEOUT_SEC=30

# docker compose only (optional)
# HOST_PORT=8080
#
# docker-compose.ghcr.yml — 使用已构建镜像时的标签，例如:
# IMAGE_TAG=latest
# IMAGE_TAG=1.0.2
#
# docker-compose.yml（本地 build）:
# IMAGE_TAG=local

